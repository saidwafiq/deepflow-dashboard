{
  "name": "deepflow-dashboard",
  "version": "0.1.94",
  "description": "Local and team analytics dashboard for Claude Code / deepflow",
  "type": "module",
  "bin": {
    "deepflow-dashboard": "./bin/cli.js"
  },
  "scripts": {
    "build": "vite build && tsc --project tsconfig.json && cp src/db/schema.sql dist/db/schema.sql && mkdir -p dist/data && cp src/data/pricing-fallback.json dist/data/pricing-fallback.json",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "hono": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.13.0",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^8.0.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "hooks/"
  ]
}
